<ContentPage
    x:Class="Nibbles.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:apiModels="clr-namespace:Nibbles.Models"
    xmlns:local="clr-namespace:Nibbles"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:Nibbles.ViewModels"
    x:Name="RootPage"
    x:DataType="viewmodels:MainPageViewModel">
    <ContentPage.Resources>
        <Style TargetType="Grid">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="Transparent" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
        <Grid Padding="5" RowDefinitions="Auto,*">
            <Grid
                Padding="10"
                ColumnDefinitions="*, Auto"
                RowDefinitions="Auto">
                <Border
                    Padding="10"
                    StrokeShape="RoundRectangle 15"
                    StrokeThickness="0"
                    Style="{StaticResource MainPageSearchBorderStyle}">
                    <Entry
                        x:Name="searchBar"
                        Margin="0"
                        BackgroundColor="Transparent"
                        HeightRequest="48"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Placeholder="Search recipes..."
                        Style="{StaticResource MainPageSearchEntryStyle}"
                        Text="{Binding SearchQuery}"
                        VerticalOptions="Center" />
                </Border>

                <Border
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    HeightRequest="48"
                    HorizontalOptions="End"
                    IsVisible="{Binding CanAdd}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 15"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    WidthRequest="48">
                    <Label
                        FontFamily="IconFonts"
                        FontSize="24"
                        HorizontalOptions="Center"
                        Text="{x:Static local:IconFont.FilePlusCorner}"
                        TextColor="{AppThemeBinding Light={StaticResource Black},
                                                    Dark={StaticResource White}}"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AddButton_Clicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </Grid>

            <CollectionView
                x:Name="recipeListCollectionView"
                Grid.Row="1"
                Margin="0,12,0,0"
                BackgroundColor="Transparent"
                ItemsSource="{Binding RecipeListItems}"
                SelectionChanged="OnCollectionViewSelectionChanged"
                SelectionMode="Single">
                <CollectionView.EmptyView>
                    <StackLayout
                        Padding="20"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Label
                            FontSize="16"
                            HorizontalTextAlignment="Center"
                            Text="No recipes found"
                            TextColor="{StaticResource Gray500}" />
                    </StackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemsLayout>
                    <GridItemsLayout
                        HorizontalItemSpacing="12"
                        Orientation="Vertical"
                        Span="2"
                        VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="apiModels:RecipeListItem">
                        <Grid BackgroundColor="Transparent">
                            <Border
                                Margin="0"
                                Padding="0"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="1"
                                Style="{StaticResource RecipeCardBorderStyle}">
                                <VerticalStackLayout Spacing="8">
                                    <Image
                                        Aspect="AspectFill"
                                        HeightRequest="225"
                                        HorizontalOptions="Fill"
                                        Source="{Binding ImageData}"
                                        VerticalOptions="Fill" />
                                    <Label
                                        Margin="12,0,12,12"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        MaxLines="3"
                                        Style="{StaticResource RecipeCardTitleStyle}"
                                        Text="{Binding Title}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Image
                Grid.RowSpan="2"
                HorizontalOptions="Center"
                IsVisible="{Binding IsBusy}"
                Rotation="{Binding LoadingRoatation}"
                Source="kittys.png"
                VerticalOptions="Center"
                WidthRequest="400" />
        </Grid>
    </RefreshView>
</ContentPage>
