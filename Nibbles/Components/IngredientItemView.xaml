<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Nibbles.Components.IngredientItemView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:apiModels="clr-namespace:Nibbles.Models"
    xmlns:local="clr-namespace:Nibbles"
    x:DataType="apiModels:Ingredient">
    <Grid ColumnDefinitions="auto, *">
        <local:PawCheckbox
            Grid.Column="0"
            Margin="0,0,8,0"
            IsChecked="{Binding IsChecked, Mode=TwoWay}"
            VerticalOptions="Center" />
        <Label
            Grid.Column="1"
            LineBreakMode="WordWrap"
            Text="{Binding FQIngrediantDescription}"
            VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleCheckedCommand}" />
            </Label.GestureRecognizers>
        </Label>
    </Grid>
</ContentView>
