<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Nibbles.PawCheckbox"
             x:Name="This">
    <Image
        x:Name="PawImage"
        WidthRequest="32"
        HeightRequest="32"
        Source="paw_unchecked.svg">
        <Image.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding ToggleCommand, Source={x:Reference This}}" Tapped="OnPawTapped" />
        </Image.GestureRecognizers>
    </Image>
</ContentView>
